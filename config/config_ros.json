{
    /*** ROS-related config for Unitree Go2-W ***/
    "glim_ros": {
        // Backend modules
        "enable_local_mapping": true,
        "enable_global_mapping": true,
        // Points config
        "keep_raw_points": false,
        // IMU config
        "imu_time_offset": 0.0,
        "points_time_offset": 0.0,
        "acc_scale": 0.0,
        // TF config
        "imu_frame_id": "imu_link",
        "lidar_frame_id": "hesai_lidar",
        "base_frame_id": "",
        "odom_frame_id": "odom",
        "map_frame_id": "map",
        "publish_imu2lidar": true,
        "tf_time_offset": 1e-6,
        // Extension modules
        "extension_modules": [
            "libmemory_monitor.so",
            "librviz_viewer.so"
        ],
        // Topics — Go2-W sensor topics
        "imu_topic": "/go2/imu",
        "points_topic": "/hesai/pandar",
        "image_topic": "/image",
        // QoS options
        "imu_qos": {
            "profile": "sensor_data",
            "depth": 1000
        },
        "points_qos": {
            "profile": "sensor_data"
        },
        "image_qos": {
            "profile": "sensor_data"
        }
    }
}
